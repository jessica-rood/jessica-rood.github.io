@techreport{cunha2026beliefs,
  abbr        = {NBER},
  bibtex_show = {true},
  title       = {Beliefs, Attention, and Investments in Early Childhood},
  author      = {Cunha, Fl\'avio and Nihtianova, Snejana and Rood, Jessica and van der Merwe, Anja-Lize},
  year        = {2026},
  institution = {National Bureau of Economic Research},
  type        = {NBER Working Paper},
  number      = {35150},
  category    = {working_paper},
  html        = {https://www.nber.org/papers/w35150},
  selected    = {true},
  abstract    = {We evaluate the LENA Start Program, a group-based parent education intervention designed to increase early language exposure for children from low-income families, using a randomized controlled trial conducted with Alief Independent School District in Houston. Intent-to-treat analyses find significant effects on parental knowledge (0.50 SD) and beliefs (0.70 SD), conversational turns (0.30 SD), the broader home language environment (0.58 SD on StimQ), and child language development (0.28 SD on the LENA Developmental Snapshot). Heterogeneity analyses using causal forests find no systematic variation in treatment effects by observable characteristics. The pattern of effects suggests the intervention operates primarily through knowledge transmission rather than by building parental confidence or altering underlying preferences.}
}

@unpublished{rood_nyc_ddc,
  bibtex_show = {true},
  title       = {Eligibility Is Not Access: Childcare Frictions and Maternal Labor Supply},
  author      = {Rood, Jessica},
  year        = {2026},
  note        = {Work in progress},
  category    = {work_in_progress},
  selected    = {true},
  abstract    = {This paper develops and estimates a dynamic discrete choice model of maternal employment and childcare decisions using administrative data from New York City's 3-K for All expansion. The central contribution is a methodology that separately identifies parental preferences over childcare arrangements from the access constraints that limit choice sets---a decomposition with significant implications for policy targeting. The estimated model is used to evaluate counterfactual policies including subsidy expansions and supply-side interventions.}
}

@unpublished{rood_lee_turnover,
  bibtex_show = {true},
  title       = {Understanding Turnover in the Early Childhood Workforce},
  author      = {Rood, Jessica and Lee, Ji-Hee},
  year        = {2026},
  note        = {Work in progress},
  category    = {work_in_progress},
  abstract    = {This paper examines turnover in the early childhood education workforce using qualitative methods, asking how high staff turnover undermines the very initiatives designed to improve childcare quality. Drawing on 90+ interviews across three Texas-based quality improvement programs---Shared Services Alliances, the Early Educator Registered Apprenticeship Program, and the Pre-K Partnership Expansion Initiative---we identify a vicious cycle in which workforce instability hampers program implementation. Emerging themes include a professional-development paradox, threats to partnership viability, and a mismatch between program design and the realities of ECE careers.}
}

@unpublished{rood_houston_sc,
  bibtex_show = {true},
  title       = {Understanding Why Families Don't Enroll in Free Pre-K: A Stated Choice Experiment},
  author      = {Rood, Jessica},
  year        = {2026},
  note        = {Work in progress},
  category    = {work_in_progress},
  abstract    = {This paper implements a stated choice experiment to identify parental preferences over early childhood program attributes, in partnership with Houston-area school districts. Despite substantial public investment, roughly 60\% of eligible Houston families do not enroll in public Pre-K. By presenting hypothetical scenarios with experimentally varied attributes (cost, distance, hours, class size, setting), the study estimates the causal effect of each attribute on choice probability and converts these into willingness-to-pay measures. The work complements the revealed-preference analysis in the New York City paper.}
}

@unpublished{rood_bsl,
  bibtex_show = {true},
  title       = {Evaluating an Eight-Week Baby Sign Language Program: An {RCT} Design},
